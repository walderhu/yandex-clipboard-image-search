{
  "manifest_version": 3,
  "name": "Clipboard Image Search for Yandex",
  "description": "Search an image from the clipboard with Yandex Images by clicking the extension button.",
  "version": "0.1.0",
  "action": {
    "default_title": "Search clipboard image",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "clipboardRead",
    "tabs"
  ],
  "host_permissions": [
    "https://yandex.ru/*",
    "https://yandex.com/*"
  ]
}
